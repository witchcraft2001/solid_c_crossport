;[]===================================================================[]
;  Получить данные из стека, вывести строку (символ)
;  на экран или в вых. файл.
;
fprintf:
	pop	bc
	pop	hl
	push	hl
	push	bc
	ld	ix,4
	add	ix,sp
A4B7B:	ld	a,(hl)
	ld	(A4C70+1),a
	inc	hl
	push	hl
	or	a
	jp	z,A4C7E
	call	isupper
	or	a
	jp	z,A4C70			; false
	ld	a,(A4C70+1)
	cp	"C"			; символ
	jr	z,A4BAB
	cp	"N"			; число
	jr	z,A4BB5
	cp	"S"			; строка
	jr	z,A4BCA
	cp	"X"			; hex-число (дес. формат вывода)
	jr	z,A4BDC
	cp	"Y"			; вывод строки и колонки с ошибкой
	jr	z,A4BF0
	; default (большие буквы, не стоящие первыми)
	jp	A4C5B
	;
	; "C" вывод символа
A4BAB:	ld	a,(ix+0)
	inc	ix
	inc	ix
	jp	A4C73
	; "N" вывод числа
A4BB5:	ld	l,(ix+0)
	inc	ix
	ld	h,(ix+0)
	inc	ix
	push	ix
	call	A49BF			; вывод в файл чисел в десят. формате
	call	A05C0			; вывод строки
	jp	A4C78
	; "S" вывод строки
A4BCA:	ld	l,(ix+0)
	inc	ix
	ld	h,(ix+0)
	inc	ix
	push	ix
	call	A05C0			; вывод строки
	jp	A4C78
	; "X" вывод hex-числа (в дес.формате)
A4BDC:	ld	c,(ix+0)
	ld	b,(ix+1)
	ld	l,(ix+2)
	ld	h,(ix+3)
	ld	de,4
	add	ix,de
	ex	de,hl
	jr	A4C11
	; "Y" вывод номеров строки и колонки (также имени include-файла)
A4BF0:	ld	l,(ix+0)
	inc	ix
	ld	h,(ix+0)
	inc	ix
	ld	a,(hl)
	inc	hl
	ld	h,(hl)
	ld	l,a
	inc	hl
	inc	hl
	ld	a,(hl)
	inc	hl
	ld	h,(hl)
	ld	l,a
	inc	hl
	inc	hl
	ld	a,(hl)
	inc	hl
	ld	h,(hl)
	ld	l,a
	ld	c,(hl)			; bc=номер строки
	inc	hl
	ld	b,(hl)
	inc	hl
	ld	e,(hl)			; de=номер колонки
	inc	hl
	ld	d,(hl)
A4C11:	push	ix
	ld	hl,(index)		; индекс имени (дескриптора) файла
	push	de
	push	bc
	ld	a,l
	or	h
	jr	z,A4C2D			; имеем начальный .C файл
	ld	a,"["
	call	A05C6			; вывод "a"
	ld	hl,(D79E9)
	call	A05C0			; вывод имени include-файла
	ld	hl,T4DE4		; "] "
	call	A05C0			; вывод строки
A4C2D:	ld	hl,A4DE7		; "line "
	call	A05C0			; вывод строки
	pop	hl
	call	A49BF			; вывод номера строки (дес.формат)
	call	A05C0			; вывод строки
	ld	hl,A4DED		; " column "
	call	A05C0			; вывод строки
	pop	hl
	call	A49BF			; вывод номера колонки (дес.формат)
	call	A05C0			; вывод строки
	ld	hl,A4DF6		; ": "
	call	A05C0			; вывод строки
	ld	a,true
	ld	(D76C7),a		; уст. флаг наличия ошибок компиляции
	ld	(D78E1),a
	call	A4F3D			; ++errors  с отслеж. "too many errors"
	jr	A4C78
	; default (большие буквы, не стоящие первыми)
A4C5B:	sub	"A"
	ld	l,a			; индекс буквы
	ld	h,0
	add	hl,hl
	ld	bc,T4C8C		; таблица адресов строк
	add	hl,bc
	ld	a,(hl)
	inc	hl
	ld	h,(hl)
	ld	l,a			; hl=адрес строки
	push	ix
	call	A05C0			; вывод строки
	jr	A4C78
	; вывод маленьких букв
A4C70:	ld	a," "
A4C73:	push	ix
	call	A05C6			; вывод "a"
A4C78:	pop	ix
	pop	hl
	jp	A4B7B			; получить след. символ
	;
A4C7E:	pop	bc
	ld	hl,T4DF9		; новая строка
	call	A05C0			; вывод строки
	;call	test_Esc		; тест на Esc
	ld	hl,0
	ret





